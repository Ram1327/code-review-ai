# Database Connection URI (SQLite local or Postgres/MySQL production)
DATABASE_URL="file:./dev.db"

# JWT Token Cryptographic Signing Secret (Change to strong random value in production)
JWT_SECRET="your-production-jwt-signing-secret"

# Backend server listener port
PORT=5000

# Frontend origin URL (Used to lock down CORS access limits)
FRONTEND_URL="http://localhost:3000"

# Google Gemini generative AI model developer API key
GEMINI_API_KEY="PLACEHOLDER_KEY"
